---
import Layout from '../../layouts/Layout.astro';
import { featuredMovies, type FeaturedMovie } from '../../data/movies';

export function getStaticPaths() {
	return featuredMovies.map((movie) => ({
		params: { id: String(movie.id) },
		props: { movie },
	}));
}

type Props = {
	movie: FeaturedMovie;
};

const { movie } = Astro.props;
const sources = movie.teaserSources ?? [];
---

<Layout title={`${movie.title} | TOHO CINEMA`}>
	<main class="min-h-screen bg-black text-crt-cream">
		<section class="relative flex min-h-screen flex-col overflow-hidden">
			<div class="absolute inset-0">
				<video
					class="h-full w-full object-cover"
					poster={movie.movieImage}
					autoplay
					muted
					loop
					playsinline
					controls
				>
					{sources.map((source) => <source src={source.src} type={source.type} />)}
				</video>
				<div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-black via-black/40 to-black/20"></div>
			</div>

			<div class="relative z-10 flex min-h-screen flex-col justify-end px-6 py-10">
				<a class="mb-8 w-fit text-sm text-white/75 transition hover:text-white" href="/">戻る</a>
				<div class="max-w-3xl">
					<h1 class="text-4xl font-bold text-white">{movie.title}</h1>
					<p class="mt-5 text-base leading-7 text-white/80">{movie.description}</p>
				</div>
			</div>
		</section>
	</main>
</Layout>
