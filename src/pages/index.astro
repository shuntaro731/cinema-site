---
import CrtHero from '../components/CrtHero.astro';
import { featuredMovies } from '../data/movies';
import Layout from '../layouts/Layout.astro';
import { getMovies, getTmdbImageUrl } from '../lib/tmdb';
import type { TmdbMovie } from '../lib/tmdb';

let movies: TmdbMovie[] = [];
let errorMessage = '';

// 映画館の情報を取得
try {
	movies = await getMovies(featuredMovies.map((movie) => movie.id));
} catch (error) {
	errorMessage = error instanceof Error ? error.message : 'Failed to fetch TMDB movies.';
}

const heroMovie = movies[0];
---

<Layout title={heroMovie ? `${heroMovie.title} | CRT Movie Screen` : 'CRT Movie Screen'}>
	<main class="h-screen snap-y snap-mandatory overflow-y-auto bg-black">
		{
			errorMessage ? (
				<section class="flex min-h-screen items-center justify-center bg-[#050403] px-6 text-center text-[#f7edc5]">
					<div class="max-w-xl border border-[#f5d675]/25 bg-[#fff4be]/5 p-8">
						<p class="mb-3 text-xs uppercase tracking-[0.28em] text-[#d4b35f]">TMDB ERROR</p>
						<h1 class="mb-4 text-3xl font-semibold">映画情報を取得できませんでした</h1>
						<p class="mb-3 text-sm leading-7 text-[#d8cda9]">{errorMessage}</p>
						<p class="text-sm text-[#d8cda9]">.env.local に TMDB_API_KEY を追加すると映画情報を取得できます。</p>
					</div>
				</section>
			) : movies.length ? (
				movies.map((movie) => {
					const movieConfig = featuredMovies.find((featuredMovie) => featuredMovie.id === movie.id);
					const movieImage = getTmdbImageUrl(movie.backdropPath, 'w1280');

					return (
						<CrtHero
							movie={movie}
							videoSrc={movieConfig?.teaserUrl}
							videoZoom={movieConfig?.teaserZoom}
							imageSrc={movieImage}
						/>
					);
				})
			) : (
				<section class="flex min-h-screen items-center justify-center bg-[#050403] px-6 text-center text-[#f7edc5]">
					<p>表示できる映画がありません。</p>
				</section>
			)
		}
	</main>
</Layout>
