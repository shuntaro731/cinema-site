---
import '../styles/global.css';

type Props = {
	title?: string;
};

const { title = '映画館によるプロモーションサイト' } = Astro.props;
---

<!doctype html>
<html lang="ja" class="bg-crt-black text-crt-cream">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body class="antialiased">
		<slot />
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}
</style>
