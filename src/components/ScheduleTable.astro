---
import type { FeaturedMovie } from '../data/movies';
import CalendarDaysIcon from './icons/CalendarDaysIcon.astro';

type Props = {
	id: number;
	schedule: FeaturedMovie['schedule'];
	durationMinutes: FeaturedMovie['durationMinutes'];
};

const { id, schedule, durationMinutes } = Astro.props;
const timelineStartMinutes = 10 * 60;
const timelineEndMinutes = 23 * 60;
const minShowingGapMinutes = 180;
const showingDurationMinutes = durationMinutes;

const getShowingMinutes = (time: string) => {
	const [hourText, minuteText] = time.split(':');

	return Number(hourText) * 60 + Number(minuteText);
};

const getShowingLeft = (time: string) => {
	const minutes = getShowingMinutes(time);
	const progress = (minutes - timelineStartMinutes) / (timelineEndMinutes - timelineStartMinutes);
	const safeProgress = Math.min(Math.max(progress, 0), 1);

	return `${8 + safeProgress * 84}%`;
};

const formatShowingRange = (time: string) => {
	const startMinutes = getShowingMinutes(time);
	const endMinutes = startMinutes + showingDurationMinutes;
	const endHour = Math.floor(endMinutes / 60);
	const endMinute = endMinutes % 60;

	return `${time}〜${String(endHour).padStart(2, '0')}:${String(endMinute).padStart(2, '0')}`;
};

const getShowingRows = (showings: FeaturedMovie['schedule'][number]['showings']) => {
	const rows: (typeof showings)[] = [];

	showings
		.slice()
		.sort((first, second) => getShowingMinutes(first.time) - getShowingMinutes(second.time))
		.forEach((showing) => {
			const showingMinutes = getShowingMinutes(showing.time);
			const row = rows.find((currentRow) => {
				const lastShowing = currentRow.at(-1);

				return !lastShowing || showingMinutes - getShowingMinutes(lastShowing.time) >= minShowingGapMinutes;
			});

			if (row) {
				row.push(showing);
				return;
			}

			rows.push([showing]);
		});

	return rows;
};
---

<section aria-labelledby={`schedule-heading-${id}`} data-schedule-root>
	<div class="mb-10 flex items-center gap-3 text-white">
		<CalendarDaysIcon class="size-6 text-white rotate-355" />
		<h2 id={`schedule-heading-${id}`} class="text-lg font-semibold tracking-wide">上映スケジュール</h2>
	</div>

	<div class="overflow-x-auto">
		<table class="min-w-full table-fixed border-collapse text-center">
			<caption class="sr-only">予約日を選択</caption>
			<tbody>
				<tr>
					{schedule.map((day, index) => (
						<td class="px-4 align-bottom border-b-2 border-white/75 data-[selected=true]:border-transparent" data-selected={index === 0 ? 'true' : 'false'} data-schedule-date-cell>
							<button
								class="group relative w-full pt-7 pb-5 text-white transition hover:text-white/85"
								type="button"
								aria-pressed={index === 0 ? 'true' : 'false'}
								data-selected={index === 0 ? 'true' : 'false'}
								data-schedule-date
								data-schedule-day-index={String(index)}
							>
								{/* 選択時dot */}
								<span class="absolute top-0 left-1/2 hidden size-2 -translate-x-1/2 rounded-full bg-brand group-data-[selected=true]:block"></span>
								{/* 曜日 */}
								<span class="block text-base font-medium text-white group-data-[selected=true]:font-bold" data-schedule-day-label>{day.day}曜日</span>
								{/* 日 */}
								<span class="block text-5xl font-semibold leading-none tracking-tight text-white" data-schedule-date-label>{day.date}</span>
								{/* 月 */}
								<span class="mt-2 block text-xs font-normal text-white/55 group-data-[selected=true]:font-semibold" data-schedule-month-label>{day.month}</span>
							</button>
						</td>
					))}
				</tr>
			</tbody>
		</table>
	</div>

	<div class="mt-7">
		{schedule.map((day, index) => (
			<div
				class={index === 0 ? 'block' : 'hidden'}
				data-schedule-showings
				data-schedule-day-index={String(index)}
			>
				<div class="overflow-x-auto">
					<table class="min-w-full table-fixed border-collapse text-sm">
						<caption class="sr-only">
							{day.month}{day.date}日（{day.day}）の予約可能時間
						</caption>
						<tbody>
							{getShowingRows(day.showings).map((row) => (
								<tr class="h-20 border-b border-white/20">
									<td class="relative px-16 align-middle">
										{row.map((showing) => (
											<button
												class="absolute top-1/2 inline-flex min-w-44 -translate-x-1/2 -translate-y-1/2 flex-col items-center justify-center whitespace-nowrap rounded bg-white px-5 py-3 text-black shadow shadow-white/20 transition hover:bg-white/90"
												style={`left: ${getShowingLeft(showing.time)}`}
												type="button"
												aria-label={`${showing.format} ${formatShowingRange(showing.time)}を選択`}
											>
												<span class="text-[0.625rem] font-semibold tracking-[0.24em] text-black/55">{showing.format}</span>
												<span class="mt-1 text-sm font-semibold">{formatShowingRange(showing.time)}</span>
											</button>
										))}
									</td>
								</tr>
							))}
						</tbody>
					</table>
				</div>
			</div>
		))}
	</div>
</section>

<script>
	const scheduleRoots = document.querySelectorAll('[data-schedule-root]');

	scheduleRoots.forEach((root) => {
		const dateButtons = root.querySelectorAll('[data-schedule-date]');
		const dateCells = root.querySelectorAll('[data-schedule-date-cell]');
		const showingTables = root.querySelectorAll('[data-schedule-showings]');
		dateButtons.forEach((button) => {
			button.addEventListener('click', () => {
				const selectedIndex = button.getAttribute('data-schedule-day-index');

				dateButtons.forEach((dateButton) => {
					const isSelected = dateButton.getAttribute('data-schedule-day-index') === selectedIndex;

					dateButton.setAttribute('data-selected', String(isSelected));
					dateButton.setAttribute('aria-pressed', String(isSelected));
				});

				dateCells.forEach((dateCell, cellIndex) => {
					dateCell.setAttribute('data-selected', String(String(cellIndex) === selectedIndex));
				});

				showingTables.forEach((table) => {
					const isSelected = table.getAttribute('data-schedule-day-index') === selectedIndex;

					table.classList.toggle('hidden', !isSelected);
					table.classList.toggle('block', isSelected);
				});
			});
		});
	});
</script>
