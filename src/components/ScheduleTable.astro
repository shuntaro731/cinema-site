---
import type { FeaturedMovie } from '../data/movies';

type Props = {
	id: number;
	schedule: FeaturedMovie['schedule'];
};

const { id, schedule } = Astro.props;

const dayLabels = ['日曜日', '月曜日', '火曜日', '水曜日', '木曜日', '金曜日', '土曜日'];
const monthLabels = ['1月', '2月', '3月', '4月', '5月', '6月', '7月', '8月', '9月', '10月', '11月', '12月'];
const scheduleDates = Array.from({ length: 7 }, (_, index) => {
	const date = new Date();
	date.setDate(date.getDate() + index);

	return {
		day: dayLabels[date.getDay()],
		date: String(date.getDate()),
		month: monthLabels[date.getMonth()],
	};
});
const timelineStartMinutes = 10 * 60;
const timelineEndMinutes = 23 * 60;
const minShowingGapMinutes = 180;

const formatShowingTime = (time: string) => {
	const [hourText, minute] = time.split(':');
	const hour = Number(hourText);
	const period = hour >= 12 ? '午後' : '午前';

	return `${period}${hour}:${minute}`;
};

const getShowingMinutes = (time: string) => {
	const [hourText, minuteText] = time.split(':');

	return Number(hourText) * 60 + Number(minuteText);
};

const getShowingLeft = (time: string) => {
	const minutes = getShowingMinutes(time);
	const progress = (minutes - timelineStartMinutes) / (timelineEndMinutes - timelineStartMinutes);
	const safeProgress = Math.min(Math.max(progress, 0), 1);

	return `${8 + safeProgress * 84}%`;
};

const getShowingRows = (showings: FeaturedMovie['schedule'][number]['showings']) => {
	const rows: (typeof showings)[] = [];

	showings
		.slice()
		.sort((first, second) => getShowingMinutes(first.time) - getShowingMinutes(second.time))
		.forEach((showing) => {
			const showingMinutes = getShowingMinutes(showing.time);
			const row = rows.find((currentRow) => {
				const lastShowing = currentRow.at(-1);

				return !lastShowing || showingMinutes - getShowingMinutes(lastShowing.time) >= minShowingGapMinutes;
			});

			if (row) {
				row.push(showing);
				return;
			}

			rows.push([showing]);
		});

	return rows;
};
---

<section aria-labelledby={`schedule-heading-${id}`} data-schedule-root>
	<h2 id={`schedule-heading-${id}`} class="sr-only">上映スケジュール</h2>

	<div class="overflow-x-auto">
		<table class="min-w-full table-fixed border-collapse text-center">
			<caption class="sr-only">予約日を選択</caption>
			<tbody>
				<tr class="border-b-2 border-white/75">
					{schedule.map((day, index) => (
						<td class="px-4 align-bottom">
							<button
								class="group relative w-full pt-8 pb-5 text-white transition hover:text-white/85"
								type="button"
								aria-pressed={index === 0 ? 'true' : 'false'}
								data-selected={index === 0 ? 'true' : 'false'}
								data-schedule-date
								data-schedule-day-index={String(index)}
							>
								<span class="absolute top-0 left-1/2 hidden size-2 -translate-x-1/2 rounded-full bg-brand group-data-[selected=true]:block"></span>
								<span class="block text-lg font-bold text-white" data-schedule-day-label>{scheduleDates[index]?.day}</span>
								<span class="block text-6xl font-bold leading-none tracking-tight text-white" data-schedule-date-label>{scheduleDates[index]?.date}</span>
								<span class="mt-2 block text-sm font-bold text-white/55" data-schedule-month-label>{scheduleDates[index]?.month}</span>
							</button>
						</td>
					))}
				</tr>
			</tbody>
		</table>
	</div>

	<div class="mt-24">
		{schedule.map((day, index) => (
			<div
				class={index === 0 ? 'block' : 'hidden'}
				data-schedule-showings
				data-schedule-day-index={String(index)}
			>
				<div class="overflow-x-auto">
					<table class="min-w-full table-fixed border-collapse text-sm">
						<caption class="sr-only">
							{day.month}{day.date}日（{day.day}）の予約可能時間
						</caption>
						<tbody>
							{getShowingRows(day.showings).map((row) => (
								<tr class="h-24 border-b border-white/20">
									<td class="relative px-16 align-middle">
										{row.map((showing) => (
											<button
												class="absolute top-1/2 inline-flex min-w-32 -translate-x-1/2 -translate-y-1/2 justify-center whitespace-nowrap rounded bg-white px-6 py-3 text-sm font-bold text-black shadow shadow-white/20 transition hover:bg-white/90"
												style={`left: ${getShowingLeft(showing.time)}`}
												type="button"
												aria-label={`${showing.format} ${formatShowingTime(showing.time)}を選択`}
											>
												{formatShowingTime(showing.time)}
											</button>
										))}
									</td>
								</tr>
							))}
						</tbody>
					</table>
				</div>
			</div>
		))}
	</div>
</section>

<script>
	const dayLabels = ['日曜日', '月曜日', '火曜日', '水曜日', '木曜日', '金曜日', '土曜日'];
	const monthLabels = ['1月', '2月', '3月', '4月', '5月', '6月', '7月', '8月', '9月', '10月', '11月', '12月'];
	const scheduleRoots = document.querySelectorAll('[data-schedule-root]');

	scheduleRoots.forEach((root) => {
		const dateButtons = root.querySelectorAll('[data-schedule-date]');
		const showingTables = root.querySelectorAll('[data-schedule-showings]');

		dateButtons.forEach((button, index) => {
			const date = new Date();
			date.setDate(date.getDate() + index);

			button.querySelector('[data-schedule-day-label]')!.textContent = dayLabels[date.getDay()];
			button.querySelector('[data-schedule-date-label]')!.textContent = String(date.getDate());
			button.querySelector('[data-schedule-month-label]')!.textContent = monthLabels[date.getMonth()];

			button.addEventListener('click', () => {
				const selectedIndex = button.getAttribute('data-schedule-day-index');

				dateButtons.forEach((dateButton) => {
					const isSelected = dateButton.getAttribute('data-schedule-day-index') === selectedIndex;

					dateButton.setAttribute('data-selected', String(isSelected));
					dateButton.setAttribute('aria-pressed', String(isSelected));
				});

				showingTables.forEach((table) => {
					const isSelected = table.getAttribute('data-schedule-day-index') === selectedIndex;

					table.classList.toggle('hidden', !isSelected);
					table.classList.toggle('block', isSelected);
				});
			});
		});
	});
</script>
