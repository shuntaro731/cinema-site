---
import type { TmdbMovie } from '../lib/tmdb';

type Props = {
	movie: TmdbMovie;
	videoSrc?: string;
	videoZoom?: number;
	imageSrc?: string | null;
};

const { movie, videoSrc, videoZoom = 1, imageSrc } = Astro.props;
const screenId = `crt-screen-${movie.id}`;
---

<section class="relative flex h-screen snap-center items-center justify-center overflow-hidden bg-black">
	<div id={screenId} class="relative aspect-video w-[min(90vw,145vh)] overflow-hidden rounded-[7%] bg-black shadow-[0_0_5rem_rgba(0,0,0,0.92)]" aria-label={`${movie.title} のブラウン管ビュー`}>
		{
			imageSrc ? (
				<img
					src={imageSrc}
					alt=""
					class="absolute inset-0 h-full w-full object-cover opacity-80 saturate-75 sepia"
					data-crt-fallback
					loading="eager"
					decoding="async"
				/>
			) : null
		}
		<canvas
			class="absolute inset-0 h-full w-full bg-transparent opacity-0 transition duration-500"
			data-crt-canvas
			data-video-src={videoSrc ?? ''}
			data-video-zoom={String(videoZoom)}
		></canvas>
		<div class="pointer-events-none absolute inset-0 bg-[linear-gradient(rgba(255,255,255,0.055)_50%,rgba(0,0,0,0.12)_50%)] bg-[length:100%_0.28rem] mix-blend-soft-light"></div>
		<div class="pointer-events-none absolute inset-0 bg-[repeating-linear-gradient(90deg,rgba(255,0,0,0.045)_0,rgba(255,0,0,0.045)_0.12rem,rgba(0,255,80,0.035)_0.12rem,rgba(0,255,80,0.035)_0.24rem,rgba(0,80,255,0.04)_0.24rem,rgba(0,80,255,0.04)_0.36rem)] mix-blend-screen opacity-35"></div>
		<div class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_center,_transparent_42%,_rgba(0,0,0,0.68)_100%)]"></div>
	</div>
</section>

<script>
	import { initCrtViewer } from '../scripts/crt-viewer';

	const cleanups = Array.from(document.querySelectorAll<HTMLCanvasElement>('[data-crt-canvas]')).map((canvas) =>
		initCrtViewer({
			canvas,
			videoSrc: canvas.dataset.videoSrc || undefined,
			videoZoom: Number(canvas.dataset.videoZoom) || 1,
		}),
	);

	document.addEventListener('astro:before-swap', () => {
		cleanups.forEach((cleanup) => cleanup());
	});
</script>
