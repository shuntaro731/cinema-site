---
import type { FeaturedMovie } from '../data/movies';

type Props = {
	movies: FeaturedMovie[];
};

const { movies } = Astro.props;
const initialPoster = movies[0]?.poster ? `background-image: url("${movies[0].poster}")` : undefined;
const serializedMovies = JSON.stringify(
	movies.map((movie) => ({
		poster: movie.poster,
		sources: movie.teaserSources ?? [],
		zoom: movie.teaserZoom,
	})),
);
---

<section class="relative flex min-h-screen items-center justify-center overflow-hidden bg-black px-6 py-10">
	<div
		id="crt-screen-main"
		class="relative aspect-[16/11] w-[min(88vw,134vh)] overflow-hidden rounded-[9%] bg-black shadow-[0_0_0_0.25rem_rgb(0_0_0),0_0_2.5rem_rgb(0_0_0/90%)]"
		aria-label="ブラウン管ビュー"
	>
		<div
			class="crt-fallback-glow absolute inset-0 bg-cover bg-center opacity-70 transition duration-500"
			style={initialPoster}
			data-crt-fallback
		></div>
		<canvas
			class="absolute inset-0 h-full w-full bg-transparent opacity-0 transition duration-500"
			data-crt-canvas
			data-movies={serializedMovies}
		></canvas>
		<div class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_center,transparent_40%,rgb(0_0_0/42%)_100%)]"></div>
		<div class="crt-screen-shade pointer-events-none absolute inset-0"></div>
		<div class="crt-scanlines pointer-events-none absolute inset-0 mix-blend-soft-light"></div>
	</div>
	<nav class="absolute right-5 top-1/2 z-40 flex -translate-y-1/2 flex-col items-center gap-4" aria-label="動画ナビゲーション">
		{
			movies.map((movie, index) => (
				<button
					type="button"
					class="h-2 w-2 rounded-full bg-stone-500/35 transition-all duration-200 hover:bg-stone-300 focus:outline-none focus-visible:ring-2 focus-visible:ring-stone-300 data-[active=true]:h-5 data-[active=true]:bg-stone-300 data-[active=true]:shadow-[0_0_0.75rem_rgb(214_211_209/28%)]"
					aria-label={`Movie ${index + 1} に切り替え`}
					aria-current={index === 0 ? 'true' : 'false'}
					data-crt-nav-dot
					data-index={index}
					data-active={index === 0 ? 'true' : 'false'}
				></button>
			))
		}
	</nav>
</section>
