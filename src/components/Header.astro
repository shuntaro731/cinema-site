---
import tohoLogo from '../assets/toho-logo.svg?url';

const navItems = ['上映中', '近日公開', '劇場について'];
---

<header class="absolute left-10 right-10 top-12 z-1 flex items-center justify-between text-color-white">
	<!-- ロゴ -->
	<a class="block w-34" href="/" aria-label="TOHO CINEMA トップへ">
		<img src={tohoLogo} alt="TOHO CINEMA" />
	</a>
	<nav class="flex items-center gap-6 text-xs font-semibold tracking-wide" aria-label="グローバルナビゲーション">
		{navItems.map((item) => (
			<a class="transition hover:text-white/70" href="#">
				{item}
			</a>
		))}
		<a class="rounded-full border-1 border-color-white px-6 py-4 transition hover:bg-[#F8EDC4] hover:text-black" href="#">
			チケットを購入
		</a>
	</nav>
</header>
