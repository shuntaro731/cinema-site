---
import tohoLogo from '../assets/toho-logo.svg?url';

const navItems = [
	{ label: '上映中', href: '#' },
	{ label: '近日公開', href: '#' },
	{ label: '劇場について', href: '#' },
];
---

<header class="absolute left-10 right-10 top-12 z-1 flex items-center justify-between text-color-white" data-crt-header>
	<!-- ロゴ -->
	<a class="block w-34" href="/" aria-label="TOHO CINEMA トップへ">
		<img src={tohoLogo} alt="TOHO CINEMA" />
	</a>
	<nav class="flex items-center gap-7 text-xs font-semibold tracking-wide" aria-label="グローバルナビゲーション">
		{navItems.map((item) => (
			<a class="transition hover:text-white/70" href={item.href}>
				{item.label}
			</a>
		))}
		<a class="rounded-full border border-color-white px-6 py-4 transition hover:bg-[#F8EDC4] hover:text-black" href="#movie-detail">
			チケットを購入
		</a>
	</nav>
</header>
