---
import type { FeaturedMovie } from '../../data/movies';
import ScheduleTable from '../ScheduleTable.astro';

type Props = {
	movies: FeaturedMovie[];
};

const { movies } = Astro.props;
---

<div
	class="relative z-[60] hidden bg-black text-white"
	aria-hidden="true"
	data-crt-detail
>
	<button
		class="fixed left-10 top-12 z-[70] inline-flex size-12 items-center justify-center rounded-full border border-white/20 bg-black/30 text-white backdrop-blur transition hover:bg-white/15"
		type="button"
		aria-label="戻る"
		data-crt-detail-back
	>
		<svg class="size-5" viewBox="0 0 24 24" fill="none" aria-hidden="true">
			<path d="M19 12H5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
			<path d="M12 19L5 12L12 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
		</svg>
	</button>
	{movies.map((movie) => {
		const detailRows = [
			{ label: '制作国', value: movie.country },
			{ label: '言語', value: movie.language },
			{ label: '公開日', value: movie.releaseDate },
			{ label: '監督', value: movie.director },
		];

		return (
			<article
				class="hidden min-h-full flex-col"
				aria-hidden="true"
				data-crt-detail-panel
				data-movie-id={String(movie.id)}
				inert
				tabindex="-1"
			>
				<div class="mx-auto w-full max-w-6xl px-6 pt-16 pb-16">
					<div class="grid gap-12 lg:grid-cols-4">
						<aside class="space-y-8">
							<img
								class="w-full rounded bg-white/10 object-cover md:hidden"
								src={movie.movieImage}
								alt={`${movie.title}のポスター`}
							/>

							<div>
								<div class="space-y-3">
									{movie.screeningFormats.map((format, index) => (
										<div class={`flex items-center justify-between rounded px-5 py-3 text-sm font-bold ${index % 2 === 0 ? 'bg-brand text-black' : 'bg-white/10 text-white/85'}`}>
											<span>{format}</span>
											{index % 2 === 0 && <span aria-hidden="true">✓</span>}
										</div>
									))}
								</div>
							</div>
						</aside>

						<div class="space-y-16 lg:col-span-3">
							<ScheduleTable id={movie.id} schedule={movie.schedule} />

							<section class="grid gap-12 lg:grid-cols-2" aria-label="作品詳細">
								<div>
									<h2 class="mb-5 border-b-2 border-brand pb-4 text-lg font-bold text-white">作品情報</h2>
									<dl>
										{detailRows.map((row) => (
											<div class="flex items-center justify-between gap-6 border-b border-white/10 py-4">
												<dt class="text-sm font-bold text-white/70">{row.label}</dt>
												<dd class="text-right text-sm font-bold text-white">{row.value}</dd>
											</div>
										))}
									</dl>
								</div>

								<div>
									<h2 class="mb-5 border-b-2 border-brand pb-4 text-lg font-bold text-white">あらすじ</h2>
									<div class="space-y-6 text-base leading-8 text-white/80">
										{movie.storyline.map((paragraph) => <p>{paragraph}</p>)}
									</div>
								</div>
							</section>
						</div>
						</div>
					</div>
			</article>
		);
	})}
</div>
