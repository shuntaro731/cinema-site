---
import Header from '../Header.astro';
import MovieNav from '../MovieNav.astro';
import type { FeaturedMovie } from '../../data/movies';

type Props = {
	movies: FeaturedMovie[];
};

const { movies } = Astro.props;
const initialMovieImage = movies[0]?.movieImage ? `background-image: url("${movies[0].movieImage}")` : undefined;
const serializedMovies = JSON.stringify(
	movies.map((movie) => ({
		id: movie.id,
		movieImage: movie.movieImage,
		sources: movie.teaserSources ?? [],
		zoom: movie.teaserZoom,
	})),
);
---

<section class="relative flex min-h-screen flex-col items-center justify-center overflow-hidden bg-black px-6 py-10">
	<Header />
	<div class="relative flex w-full max-w-[123vh] flex-col items-center">
		<div
			id="crt-screen-main"
			class="relative aspect-[16/11] w-full cursor-pointer overflow-hidden rounded-[9%] bg-black shadow-[0_0_0_0.25rem_rgb(0_0_0),0_0_2.5rem_rgb(0_0_0/90%)] transition-[border-radius,box-shadow,transform] duration-500"
			aria-label="ブラウン管ビュー"
			data-crt-screen
		>
			<div
				class="crt-fallback-glow absolute inset-0 bg-cover bg-center opacity-70 transition duration-500"
				style={initialMovieImage}
				data-crt-fallback
			></div>
			<canvas
				class="absolute inset-0 h-full w-full bg-transparent opacity-0 transition duration-500"
				data-crt-canvas
				data-movies={serializedMovies}
			></canvas>
			<div class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_center,transparent_46%,rgb(0_0_0/30%)_100%)] transition-opacity duration-300" data-crt-overlay></div>
			<div class="crt-screen-shade pointer-events-none absolute inset-0 transition-opacity duration-300" data-crt-overlay></div>
			<div class="crt-scanlines pointer-events-none absolute inset-0 mix-blend-soft-light transition-opacity duration-300" data-crt-overlay></div>
		</div>
		<!-- 動画切り替えnav -->
		<MovieNav movies={movies} />
	</div>
	<div
		class="pointer-events-none absolute inset-0 z-[60] hidden px-6 py-10 text-white"
		aria-hidden="true"
		data-crt-detail
	>
		<button
			class="pointer-events-auto absolute left-10 top-12 text-sm text-white/75 transition hover:text-white"
			type="button"
			data-crt-detail-back
		>
			戻る
		</button>
		{movies.map((movie) => (
			<article
				class="hidden h-full flex-col justify-end"
				aria-hidden="true"
				data-crt-detail-panel
				data-movie-id={String(movie.id)}
				inert
				tabindex="-1"
			>
				<div class="max-w-3xl">
					<h1 class="text-4xl font-bold text-white">{movie.title}</h1>
					<p class="mt-5 text-base leading-7 text-white/80">{movie.description}</p>
				</div>
			</article>
		))}
	</div>
</section>
